---
extends: default

rules:
  comments:
    min-spaces-from-content: 1
  comments-indentation: false
  document-start: enable
  line-length:
    max: 120
    level: warning
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  truthy:
    ignore: |
      .github/workflows/*.yml
      .github/workflows/*.yaml
